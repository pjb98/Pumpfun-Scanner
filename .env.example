# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit real keys.

# PumpPortal free real-time WebSocket feed (no key required for public data stream)
PUMPPORTAL_WS_URL=wss://pumpportal.fun/api/data

# Optional: Helius RPC for holder / dev-wallet lookups
HELIUS_API_KEY=

# Optional: Discord webhook for TRADE/WATCH alerts
DISCORD_WEBHOOK_URL=

# Scanner tuning
MIN_BONDED_PCT=35          # only surface tokens at/above this bonding %
MAX_BONDED_PCT=90          # ignore migration-chase risk above this
SCORE_TRADE_THRESHOLD=75   # score >= this => TRADE label
SCORE_WATCH_THRESHOLD=55   # score >= this => WATCH label
