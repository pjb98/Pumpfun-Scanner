# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit real keys.

# PumpPortal free real-time WebSocket feed (no key required for the public stream)
PUMPPORTAL_WS_URL=wss://pumpportal.fun/api/data

# Optional: Discord webhook for GO-signal alerts (leave blank to disable)
DISCORD_WEBHOOK_URL=
GO_ALERT_COOLDOWN_MIN=30      # min minutes between GO alerts (anti-flap)

# --- persistence ---
DB_PATH=data/platform_heat.sqlite
SNAPSHOT_INTERVAL_S=60        # how often to log a platform snapshot

# --- live signal ---
GO_THRESHOLD=65               # composite heat >= this => GO
WAIT_THRESHOLD=40             # composite heat <  this => WAIT

# Trailing baseline the live signal compares "now" against
BASELINE_HOURS=6
MIN_BASELINE_SNAPSHOTS=30     # below this, cold-start on the REF_* levels below

# Cold-start reference levels — CALIBRATE these from your own data once collected
REF_LAUNCHES_PER_MIN=8
REF_MIGRATIONS_PER_HOUR=12
REF_MIG_SPEED_MIN=30          # median minutes to migrate (lower = hotter)
REF_VOL_5M_SOL=300
REF_BUYERS_5M=400
REF_PF_FROTH=40             # pump.fun froth norm (launches/min ÷ migrations/min)
REF_SOL_VOL_24H=2000000000  # SOL 24h volume norm (USD)

# SOL market data (CoinGecko by default; Binance is geo-blocked in many regions)
# SOL_PRICE_URL=https://api.coingecko.com/api/v3/simple/price?ids=solana&vs_currencies=usd&include_24hr_change=true&include_24hr_vol=true
SOL_FETCH_INTERVAL_S=60

TOKEN_TTL_MIN=90             # drop a token's trade sub this long after launch

# --- wallet P&L (optional; shows your realized/unrealized P&L on the dashboard) ---
# Leave WALLET_ADDRESS blank to disable the panel entirely.
WALLET_ADDRESS=
SOLANATRACKER_API_KEY=       # https://www.solanatracker.io/ — data API key
# SOLANATRACKER_BASE=https://data.solanatracker.io
WALLET_PNL_TTL_S=1800        # min seconds between P&L refetches (quota-friendly)
WALLET_PNL_TOP_N=5           # top winners/losers to list
